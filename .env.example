# --- Formulaire de contact (Resend) ---
# Clé API Resend — https://resend.com/api-keys
# Sans cette clé, le formulaire fonctionne en mode dégradé (demande journalisée, pas d'envoi réel).
RESEND_API_KEY=

# Email destinataire des demandes (ex: contact@aqua-service.corsica)
CONTACT_TO_EMAIL=

# (Optionnel) Expéditeur des emails — doit être un domaine vérifié dans Resend.
# Par défaut : "Aqua Service <onboarding@resend.dev>" (domaine de test Resend).
CONTACT_FROM_EMAIL=
